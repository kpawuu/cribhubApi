{
  "host": "localhost",
  "port": 3036,
  "public": "./public/",
  "origins": ["http://localhost:3000", "http://localhost:3036"],
  "paginate": {
    "default": 25,
    "max": 100
  },
  "mongodb": "mongodb://127.0.0.1:27017/rentflow_api",
  "authentication": {
    "entity": "user",
    "service": "users",
    "secret": "CHANGE_ME_IN_ENV",
    "authStrategies": ["jwt", "local"],
    "jwtOptions": {
      "header": { "typ": "access" },
      "algorithm": "HS256",
      "expiresIn": "1d"
    },
    "local": {
      "usernameField": "email",
      "passwordField": "password"
    }
  }
}

